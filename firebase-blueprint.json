{
  "entities": {
    "Drug": {
      "title": "Drug",
      "description": "Medication configuration and stock info",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "dosage": { "type": "string" },
        "color": { "type": "string" },
        "interval": { "type": "number" },
        "stock": { "type": "number" },
        "lowStockThreshold": { "type": "number" },
        "lastRefillDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "interval"]
    },
    "Record": {
      "title": "Record",
      "description": "Medication intake record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "drugId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "taken": { "type": "boolean" }
      },
      "required": ["id", "drugId", "timestamp", "taken"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User specific settings and profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "/users/{userId}/drugs/{drugId}": {
      "schema": "Drug",
      "description": "User's medications"
    },
    "/users/{userId}/records/{recordId}": {
      "schema": "Record",
      "description": "User's intake history"
    }
  }
}
